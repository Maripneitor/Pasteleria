{
  "name": "pasteleria-app",
  "version": "1.1.0",
  "description": "Sistema de gestión de pedidos para la pastelería La Fiesta",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore whatsapp_status.json --ignore .wwebjs_auth/ server.js",
    "setup": "npm install && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all",
    "db:reset": "npx sequelize-cli db:drop && npx sequelize-cli db:create && npm run setup",
    "seed:admins": "node scripts/seed_full.js",
    "seed:full": "node scripts/seed_full.js",
    "qa:smoke": "node scripts/smoke_test.js",
    "qa:contract": "node scripts/qa/verify_contract.js",
    "qa:full": "node scripts/qa/role_smoke.js"
  },
  "author": "Isaac",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^160.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.10.3",
    "mysqldump": "^3.2.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "openai": "^6.7.0",
    "playwright": "^1.58.2",
    "puppeteer": "^24.22.3",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "sequelize": "^6.37.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "whatsapp-web.js": "^1.34.2",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "proxyquire": "^2.1.3",
    "sequelize-cli": "^6.6.5"
  }
}
