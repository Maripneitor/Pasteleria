# --- CONFIGURACIÓN DEL SERVIDOR ---
PORT=3000
NODE_ENV=development

# --- BASE DE DATOS (Ajusta según tu docker-compose.yml) ---
DB_HOST=db
DB_USER=pasteleria_user
DB_PASSWORD=secure_password
DB_NAME=pasteleria_db
DB_PORT=3306
DB_SYNC_MODE=none

# --- SEGURIDAD ---
JWT_SECRET=change_this_secret_in_production

# --- CREDENCIALES ADMIN (Seed automático) ---
ADMIN_EMAIL=superadmin@lafiesta.com
ADMIN_PASSWORD=admin123

# --- EMAIL (Opcional - para notificaciones) ---
EMAIL_USER=
EMAIL_PASS=

# --- OPENAI (Opcional - para funciones de IA) ---
OPENAI_API_KEY=

# --- URLS DE LA APLICACIÓN ---
API_URL=http://localhost:3000/api
PUBLIC_APP_URL=http://localhost:5173

# --- WHATSAPP (Opcional) ---
W_SESSION_PATH=./.wwebjs_auth

# --- BRANDING ---
DEFAULT_TENANT_NAME=Mi Pastelería
DEFAULT_PRIMARY_COLOR=#ec4899
